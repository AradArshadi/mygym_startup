# myGym environment example
# Copy this file to .env and never commit real secrets.

# Environment
ENVIRONMENT=development
SECRET_KEY=change-me-for-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# Database
# Local default: sqlite. Set DB_ENGINE=mysql for MySQL deployments.
DB_ENGINE=sqlite
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# Tests
# Keep True for fast isolated tests that do not touch your MySQL database.
# Set False only when you deliberately want to test against MySQL.
USE_SQLITE_FOR_TESTS=True
TEST_DB_NAME=test_mygym

# Email system
# Local development: prints emails to the terminal.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Real SMTP example:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_TIMEOUT=20
DEFAULT_FROM_EMAIL=myGym <noreply@mygym.local>
SERVER_EMAIL=myGym <noreply@mygym.local>
SUPPORT_EMAIL=myGym <support@mygym.local>
SITE_URL=http://127.0.0.1:8000

# Demo/test tools
# Keep False in real production. Enable only on local/demo servers if you want Control Deck demo seeding.
DEMO_TOOLS_ENABLED=True

# Upload safety
MAX_GYM_IMAGE_UPLOAD_MB=5
ALLOWED_GYM_IMAGE_EXTENSIONS=jpg,jpeg,png,webp

# Production security
USE_X_FORWARDED_HOST=False
SECURE_PROXY_SSL_HEADER_ENABLED=False
# For production set ENVIRONMENT=production, DEBUG=False, real SECRET_KEY,
# real ALLOWED_HOSTS, and HTTPS values below.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Logging
LOG_LEVEL=INFO
LOG_ALL_REQUESTS=False

# Geoapify Places API
GEOAPIFY_API_KEY=
