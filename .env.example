# Email system
# Local/dev default: prints emails to the console.
# For SMTP on PythonAnywhere, set EMAIL_BACKEND to django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=myGym <noreply@mygym.local>
SUPPORT_EMAIL=myGym <support@mygym.local>
SITE_URL=http://127.0.0.1:8000

